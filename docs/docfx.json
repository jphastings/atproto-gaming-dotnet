{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../src/ByJP.AtprotoGaming.Core",
          "files": ["**/*.csproj"]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "netstandard2.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": ["api/**.yml", "api/index.md"] },
      { "files": ["index.md", "toc.yml"] }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "ByJP.AtprotoGaming.Core",
      "_appTitle": "ByJP.AtprotoGaming.Core",
      "_description": "Engine-agnostic AT Protocol core for games — publish play-throughs to a player's PDS.",
      "_enableSearch": true,
      "_disableContribution": false,
      "pdf": false
    }
  }
}
